@page "/events"
@rendermode InteractiveServer
@inject IEventRepository EventRepo
@inject IMonitorRepository MonitorRepo

<PageTitle>Event History - PolyMon</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Event History</MudText>

<MudPaper Class="pa-4 mb-4" Elevation="1">
    <MudGrid>
        <MudItem xs="12" sm="3">
            <MudDatePicker Label="From" @bind-Date="_from" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudDatePicker Label="To" @bind-Date="_to" />
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudSelect T="int?" Label="Monitor" @bind-Value="_selectedMonitorId" Clearable="true">
                @foreach (var m in _monitors)
                {
                    <MudSelectItem T="int?" Value="@((int?)m.MonitorId)">@m.Name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex align-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="LoadAsync">Search</MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudDataGrid T="MonitorEvent" Items="@_events" Dense="true" Hover="true"
                 SortMode="SortMode.Single" Filterable="false">
        <Columns>
            <TemplateColumn Title="Time">
                <CellTemplate>@context.Item.EventDt.ToLocalTime().ToString("g")</CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="e => e.Monitor!.Name" Title="Monitor" />
            <TemplateColumn Title="Status">
                <CellTemplate><StatusBadge Status="@context.Item.Status" /></CellTemplate>
            </TemplateColumn>
            <PropertyColumn Property="e => e.Message" Title="Message" />
            <TemplateColumn Title="Alert Sent">
                <CellTemplate>
                    @if (context.Item.AlertSent)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Color="Color.Info" />
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>
}

@code {
    private List<MonitorEvent> _events = [];
    private List<Monitor> _monitors = [];
    private DateTime? _from = DateTime.Today.AddDays(-7);
    private DateTime? _to = DateTime.Today.AddDays(1);
    private int? _selectedMonitorId;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _monitors = await MonitorRepo.GetAllAsync();
        await LoadAsync();
        _loading = false;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var from = _from?.ToUniversalTime() ?? DateTime.UtcNow.AddDays(-7);
        var to = _to?.ToUniversalTime() ?? DateTime.UtcNow.AddDays(1);
        _events = await EventRepo.GetHistoryAsync(from, to, _selectedMonitorId);
        _loading = false;
    }
}
