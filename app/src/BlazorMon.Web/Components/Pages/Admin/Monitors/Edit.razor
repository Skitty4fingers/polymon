@page "/admin/monitors/new"
@page "/admin/monitors/{Id:int}"
@rendermode InteractiveServer
@inject IMonitorRepository MonitorRepo
@inject IMonitorTypeRepository MonitorTypeRepo
@inject IOperatorRepository OperatorRepo
@inject IPluginScanner PluginScanner
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@using BlazorMon.Domain.Plugins

<PageTitle>@(Id.HasValue ? "Edit Monitor" : "New Monitor") - PolyMon</PageTitle>
<MudText Typo="Typo.h5" Class="mb-4">@(Id.HasValue ? "Edit Monitor" : "New Monitor")</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudPaper Class="pa-4" Elevation="1">
        <MudForm @ref="_form" @bind-IsValid="_isValid">
            <MudGrid>
                <MudItem xs="12" sm="6">
                    <MudTextField T="string" Label="Monitor Name" @bind-Value="_monitor.Name"
                                  Required="true" MaxLength="50" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="int" Label="Monitor Type" @bind-Value="_monitor.MonitorTypeId"
                               Required="true" AnchorOrigin="Origin.BottomLeft">
                        @foreach (var mt in _monitorTypes)
                        {
                            <MudSelectItem T="int" Value="@mt.MonitorTypeId">@mt.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudNumericField T="int" Label="Trigger Mod" @bind-Value="_monitor.TriggerMod"
                                     Min="1" HelperText="Run every N cycles" />
                </MudItem>
                <MudItem xs="12" sm="1">
                    <MudCheckBox T="bool" Label="Enabled" @bind-Value="_monitor.IsEnabled" />
                </MudItem>
            </MudGrid>

            @if (_currentDescriptor is not null)
            {
                <MudDivider Class="my-4" />
                <MudText Typo="Typo.subtitle1" Class="mb-3">Plugin Configuration (@_currentDescriptor.DisplayName)</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary mb-3">@_currentDescriptor.Description</MudText>
                <PluginConfigEditor Descriptor="@_currentDescriptor"
                                    @bind-ConfigXml="_monitor.MonitorXml" />
            }

            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle1" Class="mb-2">Alert Rules</MudText>
            <MudGrid>
                <MudItem xs="6" sm="3">
                    <MudCheckBox T="bool" Label="Alert on new failure" @bind-Value="_monitor.AlertAfterEveryNewFailure" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudCheckBox T="bool" Label="Alert on fail → OK" @bind-Value="_monitor.AlertAfterEveryFailToOk" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudCheckBox T="bool" Label="Alert on new warning" @bind-Value="_monitor.AlertAfterEveryNewWarning" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudCheckBox T="bool" Label="Alert on warn → OK" @bind-Value="_monitor.AlertAfterEveryWarnToOk" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField T="int" Label="Alert every N events (0=off)" @bind-Value="_monitor.AlertAfterEveryNEvent" Min="0" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle1" Class="mb-2">Offline Times (suppress alerts)</MudText>
            <MudGrid>
                <MudItem xs="6" sm="3">
                    <MudTextField T="string" Label="Window 1 Start (HH:mm)" @bind-Value="_monitor.OfflineTime1Start" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudTextField T="string" Label="Window 1 End (HH:mm)" @bind-Value="_monitor.OfflineTime1End" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudTextField T="string" Label="Window 2 Start (HH:mm)" @bind-Value="_monitor.OfflineTime2Start" />
                </MudItem>
                <MudItem xs="6" sm="3">
                    <MudTextField T="string" Label="Window 2 End (HH:mm)" @bind-Value="_monitor.OfflineTime2End" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-4" />
            <MudText Typo="Typo.subtitle1" Class="mb-2">Operators</MudText>
            <MudGrid>
                @foreach (var op in _allOperators)
                {
                    <MudItem xs="6" sm="3">
                        <MudCheckBox T="bool" Label="@op.Name"
                                     Value="@_selectedOperatorIds.Contains(op.OperatorId)"
                                     ValueChanged="@((v) => ToggleOperator(op.OperatorId, v))" />
                    </MudItem>
                }
            </MudGrid>

            <MudStack Row="true" Class="mt-4" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveAsync"
                           Disabled="!_isValid">Save</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo("/admin/monitors"))">Cancel</MudButton>
            </MudStack>
        </MudForm>
    </MudPaper>
}

@code {
    [Parameter] public int? Id { get; set; }

    private Monitor _monitor = new();
    private List<MonitorType> _monitorTypes = [];
    private List<Operator> _allOperators = [];
    private HashSet<int> _selectedOperatorIds = [];
    private MudForm _form = null!;
    private bool _isValid;
    private bool _loading = true;
    private PluginDescriptor? _currentDescriptor;

    protected override async Task OnInitializedAsync()
    {
        _monitorTypes = await MonitorTypeRepo.GetAllAsync();
        _allOperators = await OperatorRepo.GetAllAsync();

        if (Id.HasValue)
        {
            var existing = await MonitorRepo.GetByIdAsync(Id.Value);
            if (existing is not null)
            {
                _monitor = existing;
                _selectedOperatorIds = existing.MonitorOperators.Select(mo => mo.OperatorId).ToHashSet();
            }
        }
        else
        {
            _monitor = new Monitor { IsEnabled = true, TriggerMod = 1 };
            if (_monitorTypes.Count > 0)
                _monitor.MonitorTypeId = _monitorTypes[0].MonitorTypeId;
        }

        UpdateDescriptor();
        _loading = false;
    }

    private void UpdateDescriptor()
    {
        var mt = _monitorTypes.FirstOrDefault(mt => mt.MonitorTypeId == _monitor.MonitorTypeId);
        _currentDescriptor = mt is not null ? PluginScanner.GetByKey(mt.TypeKey) : null;
    }

    private void ToggleOperator(int operatorId, bool selected)
    {
        if (selected) _selectedOperatorIds.Add(operatorId);
        else _selectedOperatorIds.Remove(operatorId);
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_isValid) return;

        if (Id.HasValue)
            await MonitorRepo.UpdateAsync(_monitor);
        else
            _monitor = await MonitorRepo.AddAsync(_monitor);

        await OperatorRepo.SetMonitorOperatorsAsync(_monitor.MonitorId, _selectedOperatorIds);

        Snackbar.Add("Monitor saved.", Severity.Success);
        Nav.NavigateTo("/admin/monitors");
    }
}
