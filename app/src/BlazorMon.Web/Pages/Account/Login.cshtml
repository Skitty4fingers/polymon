@page "/account/login"
@model BlazorMon.Web.Pages.Account.LoginModel
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BlazorMon – Sign In</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: Roboto, "Helvetica Neue", sans-serif;
            background: #1565C0;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .card {
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 24px rgba(0,0,0,.3);
            padding: 40px 48px;
            width: 400px;
        }
        .logo { font-size: 1.8rem; font-weight: 700; color: #1565C0; margin-bottom: 4px; }
        .subtitle { font-size: .85rem; color: #666; margin-bottom: 32px; }
        label { display: block; font-size: .8rem; font-weight: 500; color: #444; margin-bottom: 4px; }
        input[type=email], input[type=password] {
            width: 100%; padding: 10px 12px; border: 1px solid #ccc;
            border-radius: 4px; font-size: .95rem; margin-bottom: 16px;
            transition: border-color .2s;
        }
        input:focus { outline: none; border-color: #1565C0; }
        .remember { display: flex; align-items: center; gap: 8px; font-size: .85rem; color: #555; margin-bottom: 24px; }
        .remember input { width: auto; margin: 0; }
        button[type=submit] {
            width: 100%; padding: 12px; background: #1565C0; color: #fff;
            border: none; border-radius: 4px; font-size: 1rem; font-weight: 500;
            cursor: pointer; transition: background .2s;
        }
        button[type=submit]:hover { background: #0d47a1; }
        .error {
            background: #fce4ec; color: #b71c1c; padding: 10px 12px;
            border-radius: 4px; font-size: .85rem; margin-bottom: 16px;
        }
    </style>
</head>
<body>
    <div class="card">
        <div class="logo">BlazorMon</div>
        <div class="subtitle">Infrastructure Monitor</div>

        @if (Model.ErrorMessage is not null)
        {
            <div class="error">@Model.ErrorMessage</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <label for="email">Email address</label>
            <input type="email" id="email" name="Input.Email" value="@Model.Input.Email"
                   autofocus required />

            <label for="password">Password</label>
            <input type="password" id="password" name="Input.Password" required />

            <div class="remember">
                <input type="checkbox" id="remember" name="Input.RememberMe"
                       @(Model.Input.RememberMe ? "checked" : "") />
                <label for="remember" style="margin:0;font-weight:normal">Remember me</label>
            </div>

            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button type="submit">Sign in</button>
        </form>
    </div>
</body>
</html>
